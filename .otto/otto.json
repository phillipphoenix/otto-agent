{
  "agent": {
    "command": "claude",
    "args": [
      "-p",
      "--dangerously-skip-permissions"
    ],
    "model": "sonnet",
    "denyList": [".env", "**/.env", "*.pem", "*.key"]
  },
  "defaults": {
    "workflow": "default",
    "maxIterations": 0,
    "delay": 0,
    "timeout": null,
    "stopOnError": false,
    "logDir": null
  }
}
